---
interface Props {
    title: string;
    description: string;
    stack?: string[];
    href?: string;
}

const { title, description, stack = [], href } = Astro.props;
---

<article class="card">
    <h3>{title}</h3>
    <p>{description}</p>

    {
        stack.length > 0 && (
            <ul class="stack">
                {stack.map((item) => (
                    <li>{item}</li>
                ))}
            </ul>
        )
    }

    {href && <a href={href}>View project</a>}
</article>

<style>
    .card {
        padding: 1.5rem;
        border-radius: 20px;
        background: var(--surface);
        border: 1px solid var(--border);
    }

    h3 {
        margin-top: 0;
        margin-bottom: 0.75rem;
    }

    p {
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        padding: 0;
        margin: 0 0 1rem;
        list-style: none;
    }

    .stack li {
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: rgb(255 255 255 / 0.06);
        font-size: 0.9rem;
    }
</style>
