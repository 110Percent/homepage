---
import { Icon } from "astro-icon/components";
import { stackColours } from "../data/projects.json";
import Link from "./Link.astro";

interface Media {
    type: "image" | "video";
    src: string;
}

interface Props {
    title: string;
    description: string;
    stack?: string[];
    href?: string;
    media?: Media;
}

const { title, description, stack = [], href, media } = Astro.props;

function getStackColour(item: string): string {
    return Object.keys(stackColours).includes(item)
        ? stackColours[item as keyof typeof stackColours]
        : "#8f9db3";
}

function getStackRgb(item: string): string {
    const colour = getStackColour(item);
    const r = parseInt(colour.slice(1, 3), 16);
    const g = parseInt(colour.slice(3, 5), 16);
    const b = parseInt(colour.slice(5, 7), 16);

    return `${r} ${g} ${b}`;
}

function getLinkIcon(href: string): string {
    if (href.includes("github.com")) {
        return "mdi:github";
    } else {
        return "mdi:web";
    }
}
---

<article class="card">
    <div class="text-section">
        <h3>{title}</h3>
        <p>{description}</p>

        <div>
            {
                stack.length > 0 && (
                    <ul class="stack">
                        {stack.map((item) => (
                            <li style={`--stack-rgb: ${getStackRgb(item)};`}>
                                {item}
                            </li>
                        ))}
                    </ul>
                )
            }
        </div>

        {
            href && (
                <div>
                    <Icon name={getLinkIcon(href)} />
                    <Link href={href} refer>
                        View project
                    </Link>
                </div>
            )
        }
    </div>
    {
        media && (
            <div class="media-section">
                {media.type === "image" ? (
                    <img
                        src={media.src}
                        alt={title}
                        loading="lazy"
                        decoding="async"
                    />
                ) : (
                    <video src={media.src} autoplay muted loop />
                )}
            </div>
        )
    }
</article>

<style>
    .card {
        padding: 1.5rem;
        border-radius: 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        gap: 2rem;
        margin: 1rem 0;
    }

    h3 {
        margin-top: 0;
        margin-bottom: 0.75rem;
    }

    p {
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        padding: 0;
        margin: 0 0 1rem;
        list-style: none;
    }

    .stack li {
        --stack-rgb: 143 157 179;

        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.7rem;
        border-radius: 0.6rem;
        border: 1px solid rgb(255 255 255 / 0.14);
        background: linear-gradient(
            180deg,
            rgb(255 255 255 / 0.1) 0%,
            rgb(255 255 255 / 0.05) 100%
        );
        color: rgb(241 245 249 / 0.92);
        font-size: 0.78rem;
        font-weight: 650;
        letter-spacing: 0.015em;
        line-height: 1;
        box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.04);
    }

    .stack li::before {
        content: "";
        width: 0.38rem;
        height: 0.38rem;
        border-radius: 999px;
        background: rgb(var(--stack-rgb));
        box-shadow: 0 0 0 2px rgb(var(--stack-rgb) / 0.25);
        flex: 0 0 auto;
    }

    .text-section {
        flex-grow: 1.5;
        max-width: calc(50% - 2rem);
        margin: auto;
    }

    .media-section {
        flex: 1;
        display: flex;
        max-width: calc(50% - 2rem);
        justify-content: center;
        align-items: center;
    }

    .media-section img,
    .media-section video {
        border-radius: 12px;
        border: 1px solid var(--border);
        max-height: 300px;
        max-width: 100%;
    }

    .card [data-icon] {
        font-size: 1em;
        vertical-align: baseline;
    }

    @media (max-width: 800px) {
        .card {
            flex-direction: column;
        }

        .text-section {
            max-width: 100%;
        }

        .media-section {
            order: -1;
            width: 100%;
        }

        .media-section img,
        .media-section video {
            width: 100%;
        }
    }
</style>
