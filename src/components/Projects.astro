---
import ProjectCard from "./ProjectCard.astro";

interface Project {
    title: string;
    description: string;
    stack?: string[];
    href?: string;
}

interface Props {
    projects: Project[];
}

const { projects } = Astro.props;
---

<section id="work" class="section">
    <div class="inner">
        <p class="eyebrow">Selected work</p>
        <h2>Things I've built</h2>

        <div class="grid">
            {projects.map((project) => <ProjectCard {...project} />)}
        </div>
    </div>
</section>
